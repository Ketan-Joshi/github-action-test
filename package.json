{
  "name": "cdk-nginx-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "watch": "tsc -w",
    "cdk": "cdk",
    "diff": "cdk diff --app 'npx ts-node bin/app.ts'",
    "deploy": "cdk deploy --all --app 'npx ts-node bin/app.ts' --require-approval never",
    "deploy:lz": "cdk deploy \"${APP_ENV:-dev}-LandingZoneStack\" --app 'npx ts-node bin/app.ts' --require-approval never",
    "deploy:ecs": "cdk deploy \"${APP_ENV:-dev}-EcsAppsStack\" --app 'npx ts-node bin/app.ts' --require-approval never",
    "destroy:ecs": "cdk destroy \"${APP_ENV:-dev}-EcsAppsStack\" --app 'npx ts-node bin/app.ts' --force",
    "destroy:lz": "cdk destroy \"${APP_ENV:-dev}-LandingZoneStack\" --app 'npx ts-node bin/app.ts' --force"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "aws-cdk": "2.x",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib": "2.x",
    "constructs": "^10.0.0"
  }
}